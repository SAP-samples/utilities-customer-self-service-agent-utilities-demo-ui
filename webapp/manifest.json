{
  "_version": "1.65.0",
  "sap.app": {
    "id": "com.sap.utl.ai.ui.dssa",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "dataSources": {
      "mainService": {
        "uri": "/dssa/Conversation/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      },
      "testCaseService": {
        "uri": "/TestCase/",
        "type": "OData",
        "settings": {
          "odataVersion": "4.0"
        }
      }
    },
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:basic",
      "version": "1.15.3",
      "toolsId": "57b10ab5-33fe-4b0b-9377-092ddddd7649"
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.130.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.ui.integration": {},
        "sap.tnt": {},
        "sap.viz": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "testCase": {
        "dataSource": "testCaseService",
        "preload": true,
        "settings": {
          "synchronizationMode": "None",
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "configText": {
        "type": "sap.ui.model.json.JSONModel"
      },
      "user": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "/user-api/currentUser"
      },
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "com.sap.utl.ai.ui.dssa.i18n.i18n"
        }
      },
      "config": {
        "type": "sap.ui.model.json.JSONModel",
        "uri": "/config"
      }
    },
    "resources": {
      "css": [
        {
          "uri": "css/style.css"
        },
        {
          "uri": "css/message-input.css"
        }
      ]
    },
    "rootView": {
      "viewName": "com.sap.utl.ai.ui.dssa.view.App",
      "type": "XML",
      "async": true,
      "id": "App"
    }
  }
}