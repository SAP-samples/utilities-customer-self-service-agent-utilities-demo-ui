<mvc:View controllerName="com.sap.utl.ai.ui.dssa.controller.Chats"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true" xmlns:w="sap.ui.integration.widgets" xmlns:dssa="com.sap.utl.ai.ui.dssa.control"
    xmlns="sap.m" xmlns:core="sap.ui.core">
    <Page id="page" class="dssaMessagePage">
        <headerContent>
            <FlexBox id="page-header" width="100%" class="dssaMessagePageHeaderBox"
				alignItems="Center"
				justifyContent="SpaceBetween">
                <HBox id="page-header-left" class="dssaPageHeaderHBox sapUiTinyMarginBegin sapUiTinyMarginTop">
				    <Title id="page-title" text="{= ${configText>/chatPageTitle} ? ${configText>/chatPageTitle} : 'OpenUtil Ltd.' }" class="dssaMessagePageTitle" />
                </HBox>
                <HBox id="page-header-right" class="dssaPageHeaderHBox sapUiTinyMarginTop">
                    <Button id="page-user-edit" icon="sap-icon://user-edit" class="dssaMessagePageHeaderButtons" tooltip="Change a user" press="confirmChangeUser" />    
                    <Button id="page-more-options" icon="sap-icon://overflow" class="dssaMessagePageHeaderButtons" press="openMoreOptionsMenu" ariaHasPopup="Menu" />
                    <Button id="page-close" icon="sap-icon://decline" class="dssaMessagePageHeaderButtons" press="stopSession" tooltip="Stop session" />
                </HBox>
            </FlexBox>
        </headerContent>
        <content>
            <List 
                id="list" 
                showNoData="false"
                items="{chatMessages>/}"
                growing="true"
                growingThreshold="100000"
                class="dssaMessageListUl">
                    <items>
                        <dssa:ChatMessageItem 
                            id="item" 
                            from="{chatMessages>from}" 
                            type="{chatMessages>type}"
                            message="{chatMessages>text}"
                            cardManifest="{chatMessages>manifest}"
                            buttons="{chatMessages>buttons}"
                            apiDataKey="{chatMessages>apiDataKey}" />
                    </items>
            </List>
        </content>
        <footer>
            <Bar id="footer-toolbar" class="dssaFooterToolbar">
              <contentMiddle>
                <core:Fragment fragmentName="com.sap.utl.ai.ui.dssa.view.MessageInput" type="XML"/>
              </contentMiddle>  
            </Bar>
        </footer>
    </Page>
</mvc:View>
