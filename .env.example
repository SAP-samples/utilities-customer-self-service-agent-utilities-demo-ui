# Copy this file to .env and fill in your values.
# .env is listed in .gitignore – never commit real credentials.

# ---------------------------------------------------------------------------
# IAS / OAuth2 – client credentials for token fetching
# ---------------------------------------------------------------------------
IAS_URL=https://<your-tenant>.accounts.ondemand.com
CLIENT_ID=<your-client-id>
CLIENT_SECRET=<your-client-secret>
# Name of the IAS application provider (without the "urn:sap:identity:..." prefix)
IAS_RESOURCE=<your-ias-resource-name>

# ---------------------------------------------------------------------------
# Destination – backend URL the UI proxies requests to
# ---------------------------------------------------------------------------
DESTINATION_URL=https://<your-tenant>.ucssa.ai.cloud.sap

# ---------------------------------------------------------------------------
# UI – frontend user list served to the browser
# ---------------------------------------------------------------------------
# Display name shown in the UI header
FIRSTNAME=<Firstname>
# JSON array of users selectable in the UI
# Each entry requires: ucssa-userid, ucssa-username, businessPartners (array)
USERS=[{"ucssa-userid":"<userId>","businessPartners":["<businessPartnerId>"],"ucssa-username":"<Display Name>"}]

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------
# Host port the UI is published on (default: 8080)
UI_PORT=8080
