{
  "name": "utilities-customer-self-service-agent-utilities-demo-ui",
  "version": "0.0.1",
  "description": "Utilities Customer Self-Service Agent",
  "type": "module",
  "keywords": [
    "ui5",
    "openui5",
    "sapui5"
  ],
  "main": "webapp/index.html",
  "dependencies": {
    "@sap/html5-app-deployer": "7.2.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.8.3",
    "@sap-ux/ui5-middleware-fe-mockserver": "^2.4.13",
    "@sap/ux-ui5-tooling": "1.23.0",
    "@ui5/cli": "4.0.52",
    "axios": "1.16.0",
    "cross-env": "10.1.0",
    "fs-extra": "11.3.5"
  },
  "scripts": {
    "start": "fiori run --config ./ui5-local.yaml --open \"index.html\"",
    "start-mock": "fiori run --config ./ui5-mock.yaml --open \"index.html?dssa-mock=true\""
  },
  "sapuxLayer": "CUSTOMER_BASE"
}
